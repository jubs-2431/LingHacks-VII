APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO
API_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
PUBLIC_WEB_URL=http://localhost:3000
SHARE_URL_TEMPLATE=http://localhost:3000/shared/{token}
DATABASE_URL=sqlite:///./eldershield.db
REDIS_URL=
AUTO_CREATE_SCHEMA=true

JWT_SECRET=development-only-change-this-secret
JWT_ISSUER=eldershield-api
JWT_AUDIENCE=eldershield-client
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30
ENCRYPTION_KEY=

REPORT_RETENTION_DAYS=30
AUDIT_RETENTION_DAYS=365
SHARE_LINK_HOURS=72
SHARE_LINK_MAX_ACCESSES=20
MAX_UPLOAD_BYTES=10485760
MAX_TEXT_CHARACTERS=200000
MAX_DOCUMENT_PAGES=200
MAX_OCR_PAGES=50
MAX_IMAGE_PIXELS=40000000
OCR_TIMEOUT_SECONDS=30
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_REQUESTS=20
TRUST_PROXY_HEADERS=false

METRICS_BEARER_TOKEN=
